          "comment": "[initvar]变量初始化勿开",
          "content": "# yaml-language-server: $schema=../../schema.json\n游戏:\n  已初始化: false\n  主菜单: true\n  历法: ''\n  地域编号: capital\n  日程阶段: 0\n  游玩模式: 自主\n  地点: 太和殿（金銮宝殿）\n  天气:\n    名称: 晴\n    描述: 天朗气清，紫气东来\n    图标: ☀️\n  预设编号: ''\n  自定义模式: false\n  自定义朝代: 大明\n  自定义身份: ''\n  自定义历法: ''\n  自定义背景: ''\n  自定义已发生: ''\n  自定义未发生: ''\n角色:\n  name: ''\n  age: 22\n  dynasty: ''\n  identity: ''\n  title: ''\n  avatarSeed: ''\n  avatarUrl: ''\n  background: ''\n  attributes:\n    health: 100\n    prestige: 50\n    gold: 1000\n    military: 50\n    defense: 50\n    strength: 2\n    agility: 2\n    stamina: 2\n    intelligence: 2\n    luck: 2\n    fitness: 100\n    satiety: 100\n    energy: 0\n    energyMax: 0\n    perception: 2\n    resolve: 2\n    charm: 2\n    manipulation: 2\n    composure: 2\n    illness: ''\n    wisdomIndex: 0\n    benevolenceIndex: 0\n  status: []\n  illness: ''\n  experience: 0\n帝国:\n  summary: 山河清定，政令畅达。\n  officials: 0\n  treasury: 0\n  sentiment: 50\n  military: 0\n  grain: 0\n  annualIncome: 0\n  annualExpense: 0\n任务: {}\n技能: {}\n物品: {}\nNPC: {}\n地域: {}\n编年: []\n对话历史: []\n当前剧情:\n  story: ''\n  choices: []\n  worldEvent: ''\n  foundItem: ''\n  attainedSkill: ''",
